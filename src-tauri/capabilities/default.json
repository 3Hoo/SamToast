{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability",
  "windows": ["main", "notification-*", "settings"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:read-dirs",
    { "identifier": "fs:scope-app-recursive", "allow": [] },
    { "identifier": "fs:scope", "allow": [{ "path": "**" }] }
  ]
}
